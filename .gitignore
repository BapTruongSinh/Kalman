# Agent skill mirrors copied from external tool ecosystems.
# Keep project domain skills in .claude/.claude/skills/<domain>/, but do not
# commit thousands of mirrored skills for every agent runtime.
.claude/.claude/skills/.antigravitySkill/
.claude/.claude/skills/.claudeSkill/
.claude/.claude/skills/.codexSkill/
.claude/.claude/skills/.cursorSkill/
