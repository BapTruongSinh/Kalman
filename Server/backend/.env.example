# Copy this file to .env and fill in the values.
# Never commit the real .env file.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ENV=development
# Optional: set to false to run with DEBUG off locally
# DJANGO_DEBUG=true

DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# --- Production (set DJANGO_ENV=production) ---
# DJANGO_SECRET_KEY=         # REQUIRED — no dev fallback
# DJANGO_ALLOWED_HOSTS=api.example.com
# CORS_ALLOWED_ORIGINS=https://dashboard.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://dashboard.example.com
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# Behind reverse proxy terminating TLS:
# DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
# DJANGO_SECURE_SSL_REDIRECT=false

# Dashboard GET /api/runs* — when DJANGO_ENV=production, defaults to **true**
# (IsAuthenticated). Set to false only for intentional open read APIs.
# In development, defaults to false unless you set DASHBOARD_REQUIRE_AUTH=true.
# DASHBOARD_REQUIRE_AUTH=false

DB_NAME=kalman_greenhouse
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Server-side ARX artifact used by live ingest; request payloads cannot override it.
# ARX_MODEL_PATH=../../ARX/arx_model.json
