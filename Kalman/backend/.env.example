# Copy this file to .env and fill in the values.
# Never commit the real .env file.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ENV=development
# Optional: set to false to run with DEBUG off locally
# DJANGO_DEBUG=true

DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# --- Production (set DJANGO_ENV=production) ---
# DJANGO_SECRET_KEY=         # REQUIRED — no dev fallback
# DJANGO_ALLOWED_HOSTS=api.example.com
# CORS_ALLOWED_ORIGINS=https://dashboard.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://dashboard.example.com
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# Behind reverse proxy terminating TLS:
# DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
# DJANGO_SECURE_SSL_REDIRECT=false

# Require auth on dashboard GET /api/runs* (default false for local demo)
# DASHBOARD_REQUIRE_AUTH=false

DB_NAME=kalman_greenhouse
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
